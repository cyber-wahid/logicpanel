# Application
APP_NAME=LogicDock
APP_ENV=production
APP_DEBUG=false
APP_URL=https://panel.yourdomain.cloud
APP_TIMEZONE=UTC

# Panel Domain (Your VPS domain - CHANGE THIS!)
PANEL_DOMAIN=panel.yourdomain.cloud

# Panel Ports
MASTER_PORT=9999
USER_PORT=7777

# Database (Auto-generated by installer)
DB_CONNECTION=mysql
DB_HOST=logicdock-db
DB_PORT=3306
DB_DATABASE=logicdock
DB_USERNAME=lp_user
DB_PASSWORD=CHANGE_THIS_SECRET

# Encryption & Secrets (Auto-generated by installer)
JWT_SECRET=CHANGE_THIS_TO_RANDOM_JWT_SECRET
ENCRYPTION_KEY=CHANGE_THIS_TO_RANDOM_SODIUM_KEY

# Docker
DOCKER_NETWORK=panel_logicdock_internal
USER_APPS_PATH=/var/www/html/storage/user-apps
USER_APPS_HOST_PATH=/opt/logicdock/storage/user-apps

# Database Root Passwords (Auto-generated by installer)
MYSQL_ROOT_PASSWORD=CHANGE_THIS_SECRET
POSTGRES_ROOT_PASSWORD=CHANGE_THIS_SECRET
MONGO_ROOT_PASSWORD=CHANGE_THIS_SECRET

# Database Microservice
DB_PROVISIONER_URL=http://db-provisioner:3001
DB_PROVISIONER_SECRET=CHANGE_THIS_SECRET

# Internal Services
REDIS_HOST=redis
REDIS_PORT=6379

# Logging
# LOG_CHANNEL: app | api | php | access  (channel name, also used as log sub-directory)
LOG_CHANNEL=app
# LOG_LEVEL: debug | info | notice | warning | error | critical | alert | emergency
LOG_LEVEL=info
# Logs are written to: storage/logs/{channel}/{channel}-YYYY-MM-DD.log
# AND mirrored to stderr (visible via: docker logs logicpanel_app)
LOG_PATH=/var/www/html/storage/logs

# SSL Configuration (Automatic - No API Keys Needed!)
# SSL certificates are generated automatically using TLS-ALPN-01 Challenge
# Just point your domain's DNS A record to your server IP
ADMIN_EMAIL=admin@yourdomain.cloud
